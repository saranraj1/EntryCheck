# Set default behaviour: detect text files, normalise to LF
* text=auto eol=lf

# Explicitly LF for all source and data files
*.py    text eol=lf
*.toml  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.md    text eol=lf
*.json  text eol=lf
*.csv   text eol=lf
*.txt   text eol=lf
*.lock  text eol=lf
*.cfg   text eol=lf
*.ini   text eol=lf

# Binary files — no conversion
*.png   binary
*.jpg   binary
*.webp  binary
*.gz    binary
*.zip   binary
